# ── Required for live AI trading ──────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model to use via OpenRouter (any model they support)
# Options: anthropic/claude-sonnet-4-6, openai/gpt-4o, meta-llama/llama-3.1-70b-instruct
AI_MODEL=anthropic/claude-sonnet-4-6

# ── Langfuse observability ─────────────────────────────────────────
# Get from: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
